TZ=Asia/Shanghai
DATABASE_PATH=data/learning.db
ENABLE_SCHEDULER=true
DEFAULT_STUDENT_ID=1

# 通知：local / auto / pushplus / console / none
# local 会自动使用 macOS/Windows/Linux 本机通知；auto 会在有 PUSHPLUS_TOKEN 时同时发 PushPlus。
NOTIFY_CHANNEL=local
PUSHPLUS_TOKEN=

# 登录账号；密码留空表示不启用登录校验
CHILD_USER=child
CHILD_PASSWORD=
PARENT_USER=parent
PARENT_PASSWORD=
ADMIN_USER=admin
ADMIN_PASSWORD=

# AI Agent 配置
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
